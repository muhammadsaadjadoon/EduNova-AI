# AI Quiz Generator — Phase 1 secure configuration
APP_ENV=development
DATABASE_URL=sqlite:///./ai_quiz.db

# REQUIRED in production: use a long random value (at least 32 bytes).
AUTH_SECRET=replace-with-a-long-random-production-secret
ACCESS_TOKEN_MINUTES=20
REFRESH_TOKEN_DAYS=14

# Production must list exact trusted frontend origins, comma-separated.
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
LOGIN_RATE_LIMIT=8
RESET_RATE_LIMIT=5

# Optional SMTP password-reset delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Phase 8 database lifecycle
# Development may keep this true. Production should keep it false and run:
#   python db_manage.py upgrade
AUTO_CREATE_SCHEMA=true
# PostgreSQL production example:
# DATABASE_URL=postgresql+psycopg://quiz_user:strong_password@localhost:5432/quiz_app

# Phase 10 production operations
LOG_LEVEL=INFO
JSON_LOGS=false
POSTGRES_PASSWORD=replace-with-a-strong-database-password
BACKUP_DIR=backups
